# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=nba-player-prop

# NBA Stats (no key needed, nba_api is free)
# NBA_API_RATE_LIMIT_SLEEP=1  # seconds between requests

# The Odds API (https://the-odds-api.com/ - free tier: 500 req/month)
ODDS_API_KEY=your_odds_api_key

# MiroFish (must be running locally or on a server)
MIROFISH_BASE_URL=http://localhost:5001
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
ZEP_API_KEY=your_zep_api_key

# Schedule
CRAWL_TIMEZONE=America/Denver
CRAWL_HOUR=0
CRAWL_MINUTE=0
